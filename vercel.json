{
  "rewrites": [
    {
      "source": "/",
      "destination": "/homepage.html"
    },
    {
      "source": "/onboarding",
      "destination": "/index.html"
    },
    {
      "source": "/app",
      "destination": "/app.html"
    },
    {
      "source": "/loading",
      "destination": "/loading.html"
    },
    {
      "source": "/homepage",
      "destination": "/homepage.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}